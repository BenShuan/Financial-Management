# Postgres connection string. For Neon the URL must include ?sslmode=require
# (pg reads it from the URL; there is no code-level ssl config).
DATABASE_URL=postgresql://fm:fm@localhost:5432/financial_management

# Allowed browser origin(s) for CORS — comma-separated, no trailing slash.
# Production: the Vercel URL(s), e.g. https://your-app.vercel.app
WEB_ORIGIN=http://localhost:5173

# Temporary deployment gate: when set, every /api/* route except /api/health
# requires "Authorization: Bearer <secret>". Leave empty in local dev.
ACCESS_SECRET=

PORT=8787
